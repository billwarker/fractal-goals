# Environment Configuration Template
# Copy this file to .env and configure for your environment

# Application Environment (development, testing, production)
FLASK_ENV=development

# Flask Configuration
FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=8001
MAX_CONTENT_LENGTH=2097152
SLOW_REQUEST_THRESHOLD_MS=750

# Database Configuration
# PostgreSQL database connection (Required)
DATABASE_URL=postgresql://fractal:fractal_dev_password@localhost:5432/fractal_goals

# Frontend Configuration
VITE_API_URL=http://localhost:8001/api

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
# Extra Content-Security-Policy connect-src entries for production API/service hosts.
CSP_CONNECT_SRC=

# Logging
LOG_LEVEL=INFO
LOG_FILE=server.log

# JWT Configuration
JWT_SECRET_KEY=dev-secret-key
JWT_EXPIRATION_HOURS=72
JWT_REFRESH_WINDOW_DAYS=7
AUTH_COOKIE_NAME=fractal_auth_token
CSRF_COOKIE_NAME=fractal_csrf_token
CSRF_HEADER_NAME=X-CSRF-Token
AUTH_COOKIE_SECURE=False
AUTH_COOKIE_SAMESITE=Lax

# Database connection pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE_SECONDS=3600

# Rate Limiting / Shared Cache
# Use redis://... in full production so Gunicorn workers share limits/cache.
# Private beta may use memory:// only with ALLOW_IN_MEMORY_RATELIMIT=true,
# WEB_CONCURRENCY=1, and a single backend instance.
RATELIMIT_STORAGE_URI=memory://
ALLOW_IN_MEMORY_RATELIMIT=false

# Cloud / Monitoring
GCS_BUCKET_NAME=
GCS_SERVICE_ACCOUNT_KEY_PATH=service-account-key.json
SENTRY_DSN=
VITE_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILES_SAMPLE_RATE=1.0
