# Production Environment Configuration Example
# Copy to .env.production and fill in secrets

# Application Environment
FLASK_ENV=production

# Flask Configuration
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=8001

# Database Configuration
# Production uses Supabase Postgres.
# Prefer the session/transaction pooler URL from Supabase with sslmode=require.
# SUPABASE_DATABASE_URL=postgresql://user:password@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require

# Frontend Configuration
# Update this to your production domain
VITE_API_URL=https://your-domain.com/api

# CORS Origins
CORS_ORIGINS=https://your-domain.com

# Logging
LOG_LEVEL=WARNING
LOG_FILE=logs/prod_server.log

# Security Headers
JWT_SECRET_KEY=change-this-to-a-secure-random-string

# Deployment
AUTO_RUN_DB_MIGRATIONS=False
