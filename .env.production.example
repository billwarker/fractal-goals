# Production Environment Configuration Example
# Copy to .env.production and fill in secrets

# Application Environment
FLASK_ENV=production

# Flask Configuration
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=8001
MAX_CONTENT_LENGTH=2097152
SLOW_REQUEST_THRESHOLD_MS=750

# Database Configuration
# Production uses Supabase Postgres.
# Prefer the session/transaction pooler URL from Supabase with sslmode=require.
# SUPABASE_DATABASE_URL=postgresql://user:password@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require

# Frontend Configuration
# Update this to your production domain
VITE_API_URL=https://your-domain.com/api

# CORS Origins
CORS_ORIGINS=https://your-domain.com

# Logging
LOG_LEVEL=WARNING
LOG_FILE=logs/prod_server.log

# Security Headers
JWT_SECRET_KEY=change-this-to-a-secure-random-string
AUTH_COOKIE_SECURE=True
AUTH_COOKIE_SAMESITE=Strict
CSRF_COOKIE_NAME=fractal_csrf_token
CSRF_HEADER_NAME=X-CSRF-Token

# Rate limiting must use shared durable storage in production.
RATELIMIT_STORAGE_URI=redis://your-redis-host:6379/0

# Size this alongside Gunicorn workers/threads and database limits.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE_SECONDS=3600

# Deployment
AUTO_RUN_DB_MIGRATIONS=False
